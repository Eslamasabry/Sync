APP_ENV=production
LOG_LEVEL=INFO
DEBUG=false
ENABLE_GZIP=true
GZIP_MINIMUM_SIZE=500
CORS_ALLOW_ORIGINS=https://reader.example.com
CORS_ALLOW_ORIGIN_REGEX=
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,Origin
CORS_ALLOW_CREDENTIALS=true
TRUSTED_HOSTS=api.example.com,localhost,127.0.0.1
DATABASE_URL=postgresql+psycopg://sync:change-me@localhost:5432/sync
REDIS_URL=redis://localhost:6379/0
ALIGNMENT_WORKDIR=/var/lib/sync
OBJECT_STORE_MODE=filesystem
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
AUDIO_CHUNK_DURATION_MS=300000
TRANSCRIBER_PROVIDER=whisperx
WHISPER_MODEL_NAME=base
