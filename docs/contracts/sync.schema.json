{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/sync.schema.json",
  "title": "SyncArtifact",
  "type": "object",
  "required": ["version", "book_id", "audio", "tokens"],
  "properties": {
    "version": {
      "type": "string"
    },
    "book_id": {
      "type": "string",
      "format": "uuid"
    },
    "language": {
      "type": "string"
    },
    "audio": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["asset_id", "offset_ms", "duration_ms"],
        "properties": {
          "asset_id": {
            "type": "string",
            "format": "uuid"
          },
          "offset_ms": {
            "type": "integer",
            "minimum": 0
          },
          "duration_ms": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "tokens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "text",
          "normalized",
          "start_ms",
          "end_ms",
          "location"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 0
          },
          "text": {
            "type": "string"
          },
          "normalized": {
            "type": "string"
          },
          "start_ms": {
            "type": "integer",
            "minimum": 0
          },
          "end_ms": {
            "type": "integer",
            "minimum": 0
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "location": {
            "type": "object",
            "required": ["section_id", "paragraph_index", "token_index"],
            "properties": {
              "section_id": {
                "type": "string"
              },
              "paragraph_index": {
                "type": "integer",
                "minimum": 0
              },
              "token_index": {
                "type": "integer",
                "minimum": 0
              },
              "cfi": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["start_token_id", "end_token_id", "reason"],
        "properties": {
          "start_token_id": {
            "type": "integer",
            "minimum": 0
          },
          "end_token_id": {
            "type": "integer",
            "minimum": 0
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
