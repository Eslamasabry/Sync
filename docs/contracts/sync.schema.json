{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/sync.schema.json",
  "title": "SyncArtifact",
  "type": "object",
  "required": ["version", "book_id", "audio", "tokens"],
  "properties": {
    "version": {
      "type": "string"
    },
    "book_id": {
      "type": "string",
      "format": "uuid"
    },
    "language": {
      "type": "string"
    },
    "audio": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["asset_id", "offset_ms", "duration_ms"],
        "properties": {
          "asset_id": {
            "type": "string",
            "format": "uuid"
          },
          "offset_ms": {
            "type": "integer",
            "minimum": 0
          },
          "duration_ms": {
            "type": "integer",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "content_start_ms": {
      "type": "integer",
      "minimum": 0
    },
    "content_end_ms": {
      "type": "integer",
      "minimum": 0
    },
    "stats": {
      "type": "object",
      "required": [
        "matched_word_count",
        "unmatched_word_count",
        "transcript_word_count",
        "low_confidence_token_count",
        "content_duration_ms"
      ],
      "properties": {
        "matched_word_count": {
          "type": "integer",
          "minimum": 0
        },
        "unmatched_word_count": {
          "type": "integer",
          "minimum": 0
        },
        "transcript_word_count": {
          "type": "integer",
          "minimum": 0
        },
        "coverage_ratio": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "average_confidence": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "low_confidence_token_count": {
          "type": "integer",
          "minimum": 0
        },
        "content_duration_ms": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "tokens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "text",
          "normalized",
          "start_ms",
          "end_ms",
          "location"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 0
          },
          "text": {
            "type": "string"
          },
          "normalized": {
            "type": "string"
          },
          "start_ms": {
            "type": "integer",
            "minimum": 0
          },
          "end_ms": {
            "type": "integer",
            "minimum": 0
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "location": {
            "type": "object",
            "required": ["section_id", "paragraph_index", "token_index"],
            "properties": {
              "section_id": {
                "type": "string"
              },
              "paragraph_index": {
                "type": "integer",
                "minimum": 0
              },
              "token_index": {
                "type": "integer",
                "minimum": 0
              },
              "cfi": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "start_ms",
          "end_ms",
          "reason",
          "transcript_start_index",
          "transcript_end_index",
          "word_count"
        ],
        "properties": {
          "start_ms": {
            "type": "integer",
            "minimum": 0
          },
          "end_ms": {
            "type": "integer",
            "minimum": 0
          },
          "reason": {
            "type": "string"
          },
          "transcript_start_index": {
            "type": "integer",
            "minimum": 0
          },
          "transcript_end_index": {
            "type": "integer",
            "minimum": 0
          },
          "word_count": {
            "type": "integer",
            "minimum": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
